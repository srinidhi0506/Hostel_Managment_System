package hostel;

public class HostelBranch {
    private String name;
    private Hostel hostel;

    public HostelBranch(String name, Hostel hostel) {
        this.name = name;
        this.hostel = hostel;
    }

    public String getName() { return name; }
    public Hostel getHostel() { return hostel; }

    @Override
    public String toString() { return name; }
}
